generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  engineType      = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String?
  lastName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  // Relations
  accounts          Account[]
  categories        Category[]
  transactions      Transaction[]
  seedGoals         SeedGoal[]
  tithes            Tithe[]
  notifications     Notification[]
  settings          Settings?
}

model Settings {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @unique @db.Uuid
  theme          String   @default("light") // light, dark, system
  notifications  Boolean  @default(true)
  dailyVerse     Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  name        String
  balance     Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  name        String
  type        String   // "INCOME" | "EXPENSE"
  icon        String?
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Transaction {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  accountId   String   @db.Uuid
  categoryId  String?  @db.Uuid
  type        String   // "INCOME" | "EXPENSE" | "TRANSFER"
  amount      Float
  date        DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  account     Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

model SeedGoal {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  name           String
  targetAmount   Float
  currentAmount  Float    @default(0)
  targetDate     DateTime?
  status         String   @default("ACTIVE") // ACTIVE, HARVESTED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions SeedContribution[]
}

model SeedContribution {
  id          String   @id @default(uuid()) @db.Uuid
  seedGoalId  String   @db.Uuid
  amount      Float
  date        DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  seedGoal SeedGoal @relation(fields: [seedGoalId], references: [id], onDelete: Cascade)
}

model Tithe {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  amount      Float
  date        DateTime @default(now())
  month       Int
  year        Int
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyVerse {
  id        String   @id @default(uuid()) @db.Uuid
  verse     String
  reference String
  date      DateTime @db.Date // Ensures one verse per day
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
