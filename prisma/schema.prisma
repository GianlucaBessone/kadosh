generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  engineType      = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid()) @db.Uuid
  email     String    @unique
  name      String?
  lastName  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  settings      Settings?
  notifications Notification[]
  workspaces    WorkspaceMember[] @relation("WorkspaceMemberUser")
  invitations   WorkspaceMember[] @relation("InvitedBy")
  devices       Device[]
  events        WorkspaceEvent[]

  supportTickets        SupportTicket[]
  feedbacks             Feedback[]
  donations             Donation[]
  prayers               Prayer[]
  developerInfoRequests DeveloperInfoRequest[]
}

model Settings {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @unique @db.Uuid
  theme           String    @default("light") // light, dark, system
  notifications   Boolean   @default(true)
  dailyVerse      Boolean   @default(true)
  showReflection  Boolean   @default(true)
  offlineDownload Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum VerseCategory {
  MAYORDOMIA
  SABIDURIA
  TRABAJO
  CONFIANZA
  GENEROSIDAD
  GRATITUD
  PAZ
  FE
  ESPERANZA
}

// ─── E2EE & Event Sourcing ─────────────────────────────

model Workspace {
  id               String   @id @default(uuid()) @db.Uuid
  name             String
  type             String   @default("PERSONAL") // PERSONAL, FAMILY, BUSINESS, MINISTRY
  workspaceVersion Int      @default(1)
  ownerId          String   @db.Uuid
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  members            WorkspaceMember[]
  events             WorkspaceEvent[]
  keys               WorkspaceKey[]
  workspaceSnapshots WorkspaceSnapshot[]
}

model WorkspaceMember {
  id                 String    @id @default(uuid()) @db.Uuid
  workspaceId        String    @db.Uuid
  userId             String    @db.Uuid
  roleTemplate       String    @default("MEMBER") // OWNER, ADMIN, MEMBER, VIEWER, CUSTOM
  customCapabilities Json?
  status             String    @default("ACCEPTED") // PENDING, ACCEPTED, REJECTED, REMOVED
  invitedById        String?   @db.Uuid
  invitedAt          DateTime?
  acceptedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation("WorkspaceMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User?     @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([workspaceId, userId])
}

model Device {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @db.Uuid
  publicKey     String // Identity Public Key (Curve25519 Hex)
  deviceName    String
  trusted       Boolean   @default(false)
  deviceRole    String    @default("SECONDARY") // PRIMARY, SECONDARY
  appVersion    String?
  cryptoVersion String?
  lastSyncAt    DateTime?
  lastSeen      DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceKeys   DeviceWorkspaceKey[]
  workspaceEvents WorkspaceEvent[]
}

model WorkspaceKey {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  version     Int      @default(1)
  createdAt   DateTime @default(now())

  workspace          Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deviceKeys         DeviceWorkspaceKey[]
  events             WorkspaceEvent[]
  workspaceSnapshots WorkspaceSnapshot[]
}

model DeviceWorkspaceKey {
  id             String   @id @default(uuid()) @db.Uuid
  workspaceKeyId String   @db.Uuid
  deviceId       String   @db.Uuid
  wrappedKey     String // Workspace Key cifrada con la publicKey del Device
  createdAt      DateTime @default(now())

  workspaceKey WorkspaceKey @relation(fields: [workspaceKeyId], references: [id], onDelete: Cascade)
  device       Device       @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([workspaceKeyId, deviceId])
}

model WorkspaceEvent {
  id          String @id @default(uuid()) @db.Uuid
  workspaceId String @db.Uuid

  // ─── Metadata ──────────────────────────────────────
  aggregateId       String   @db.Uuid
  aggregateType     String
  sequence          Int
  eventType         String // e.g. "TransactionCreated", "AccountUpdated"
  eventVersion      String   @default("v1")
  schemaVersion     String   @default("1.0")
  encryptionVersion String   @default("v1")
  ownerUserId       String   @db.Uuid
  deviceId          String?  @db.Uuid
  keyId             String   @db.Uuid
  createdAt         DateTime @default(now())
  // ───────────────────────────────────────────────────

  encryptedPayload String // Cyphertext + IV en Base64
  // Los eventos son inmutables, no hay updatedAt.

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner        User         @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  device       Device?      @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  workspaceKey WorkspaceKey @relation(fields: [keyId], references: [id], onDelete: Restrict)
}

model WorkspaceSnapshot {
  id                String   @id @default(uuid()) @db.Uuid
  workspaceId       String   @db.Uuid
  snapshotVersion   Int
  schemaVersion     String   @default("1.0")
  lastEventId       String   @db.Uuid
  keyId             String   @db.Uuid
  eventCount        Int      @default(0)
  createdByDeviceId String   @db.Uuid
  snapshotPolicy    String   @default("AUTO") // AUTO, MANUAL
  encryptedPayload  String
  createdAt         DateTime @default(now())

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceKey WorkspaceKey @relation(fields: [keyId], references: [id], onDelete: Restrict)
}

model DailyVerse {
  id         String        @id @default(uuid()) @db.Uuid
  reference  String
  book       String
  chapter    Int
  verseStart Int
  verseEnd   Int?
  category   VerseCategory
  theme      String
  text       String
  reflection String?
  dayOfYear  Int // 1-365
  active     Boolean       @default(true)
  isFavorite Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  deletedAt  DateTime?
}

model Notification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  title     String
  message   String
  read      Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationIntent {
  id            String   @id @default(uuid()) @db.Uuid
  userHash      String // OneSignal external_id / user hash
  title         String
  message       String
  targetTimeUtc DateTime
  commitmentId  String? // Reference to local IndexedDB ID, used to deduplicate/cancel
  sent          Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model InactivityTracker {
  id              String   @id @default(uuid()) @db.Uuid
  userHash        String   @unique // Same as deviceId or OneSignal external_id
  accumulatedDays Int      @default(0)
  lastPulseAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Support Ticket ──────────────────────────────────
model SupportTicket {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String?  @db.Uuid
  guestId       String?
  type          String // "BUG" | "FEATURE" | "QUESTION"
  subject       String
  description   String
  screenshotUrl String?
  appVersion    String?
  browser       String?
  os            String?
  language      String?
  resolution    String?
  status        String   @default("OPEN") // OPEN | IN_PROGRESS | RESOLVED | CLOSED
  priority      String   @default("NORMAL") // LOW | NORMAL | HIGH | URGENT
  adminNotes    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Feedback ────────────────────────────────────────
model Feedback {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @db.Uuid
  guestId     String?
  type        String // "COMMENT" | "NPS"
  npsScore    Int? // 0-10
  bestPart    String?
  improvement String?
  comment     String?
  status      String   @default("NEW") // NEW | REVIEWED | ARCHIVED
  adminNotes  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Donation ────────────────────────────────────────
model Donation {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  amount        Float
  currency      String   @default("ARS")
  paymentMethod String?
  status        String   @default("PENDING") // PENDING | COMPLETED | FAILED | REFUNDED
  externalId    String? // ID de la pasarela de pago
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Prayer ──────────────────────────────────────────
model Prayer {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  guestId   String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Developer Info Request ──────────────────────────
model DeveloperInfoRequest {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String?   @db.Uuid
  guestId    String?
  status     String    @default("PENDING") // PENDING | NOTIFIED | SEEN
  notifiedAt DateTime?
  seenAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── App Config ──────────────────────────────────────
model AppConfig {
  key       String   @id
  value     String
  type      String   @default("STRING") // STRING | BOOLEAN | NUMBER | JSON
  label     String? // Etiqueta legible para el admin
  category  String   @default("GENERAL")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Admin ───────────────────────────────────────────
model Admin {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Domain Models (Read Models / Projections) ─────────
// Estos modelos NO se persisten en PostgreSQL mediante CRUD tradicional.
// Se utilizan estrictamente como tipos de dominio para el Projection Engine,
// la UI y Zustand. Su presencia en Prisma garantiza el tipado y consistencia.

model Account {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  name        String
  balance     Float     @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  transactions Transaction[]
}

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  name        String
  type        String
  icon        String?
  color       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  transactions Transaction[]
}

model Transaction {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  accountId   String    @db.Uuid
  categoryId  String?   @db.Uuid
  type        String
  amount      Float
  date        DateTime  @default(now())
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  account  Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

model SeedGoal {
  id            String    @id @default(uuid()) @db.Uuid
  workspaceId   String    @db.Uuid
  name          String
  targetAmount  Float
  currentAmount Float     @default(0)
  targetDate    DateTime?
  status        String    @default("ACTIVE")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  contributions SeedContribution[]
}

model SeedContribution {
  id         String    @id @default(uuid()) @db.Uuid
  seedGoalId String    @db.Uuid
  amount     Float
  date       DateTime  @default(now())
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  seedGoal SeedGoal @relation(fields: [seedGoalId], references: [id], onDelete: Cascade)
}

model Tithe {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  amount      Float
  date        DateTime  @default(now())
  month       Int
  year        Int
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
}
